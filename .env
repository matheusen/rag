POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=ragsys
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Ollama local (user-scoped server para evitar divergencia com o Windows service)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# OpenTelemetry
OTEL_SERVICE_NAME=rag-system
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Google / Vertex AI (desabilitado — billing inativo)
# GOOGLE_CLOUD_PROJECT=api-project-1013904049487
# GOOGLE_CLOUD_LOCATION=us-central1
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# GEMINI_LLM_MODEL=gemini-2.0-flash


# OCR — backends em cadeia: chandra2 → glm → rapid (fallback)
RAG_OCR_ENABLED=true
RAG_OCR_BACKENDS=chandra2,glm,rapid
RAG_OCR_CHANDRA_ENABLED=true
RAG_OCR_GLM_ENABLED=true
RAG_OCR_GLM_MODEL_ID=microsoft/trocr-base-printed
RAG_OCR_GLM_TASK=image-to-text
RAG_OCR_LOCAL_FILES_ONLY=false
RAG_OCR_OLLAMA_MODEL=moondream
HF_HUB_OFFLINE=1
